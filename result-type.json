{
  "type": "AdaptiveCard",
  "version": "1.3",
  "body": [
    {
      "type": "ColumnSet",
      "columns": [
        {
          "type": "Column",
          "width": 6,
          "items": [
            {
              "type": "TextBlock",
              "text": "[__${name} (Part #${partNumber})__](${itemUrl})",
              "$when": "${name != \"\"}"
            },
            {
              "type": "TextBlock",
              "text": "${description}",
              "wrap": true,
              "maxLines": 3,
              "$when": "${description != \"\"}"
            },
            {
              "type": "Image",
              "url": "${iconUrl}",
              "horizontalAlignment": "Center",
              "size": "small",
              "altText": "${name}"
            }
          ],
          "horizontalAlignment": "Center"
        },
        {
          "type": "Column",
          "width": 2,
          "items": [
            {
              "type": "FactSet",
              "facts": [
                {
                  "title": "Price",
                  "value": "$${price}"
                },
                {
                  "title": "Current Inventory",
                  "value": "${inventory} units"
                }
              ]
            }
          ],
          "horizontalAlignment": "Right"
        }
      ]
    }
  ],
  "actions": [
    {
      "type": "Action.OpenUrl",
      "title": "View Item",
      "url": "${itemUrl}"
    }
  ],
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json"
}