{
  "type": "AdaptiveCard",
  "version": "1.3",
  "body": [
    {
      "type": "ColumnSet",
      "columns": [
        {
          "type": "Column",
          "width": 6,
          "items": [
            {
              "type": "TextBlock",
              "text": "[__${name} (Part #${partNumber})__](${itemUrl})",
              "$when": "${name != \"\"}"
            },
            {
              "type": "ColumnSet",
              "columns": [
                {
                  "type": "Column",
                  "width": 2,
                  "items": [
                    {
                      "type": "Image",
                      "url": "${iconUrl}",
                      "horizontalAlignment": "Center",
                      "size": "Medium",
                      "altText": "${name}"
                    }
                  ]
                },
                {
                  "type": "Column",
                  "width": 4,
                  "items": [
                    {
                      "type": "FactSet",
                      "facts": [
                        {
                          "title": "Price",
                          "value": "$${price}"
                        },
                        {
                          "title": "Current Inventory",
                          "value": "${inventory} units"
                        }
                      ]
                    },
                    {
                      "type": "TextBlock",
                      "text": "${description}",
                      "wrap": true,
                      "maxLines": 3,
                      "$when": "${description != \"\"}",
                      "separator": true
                    }
                  ]
                }
              ]
            }
          ],
          "horizontalAlignment": "Center"
        }
      ]
    }
  ],
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json"
}